%{ endif ~}
%{ if contains(["wallarm_rule_brute", "wallarm_rule_bola", "wallarm_rule_enum"], resource_type) && enumerated_parameters != null ~}

  enumerated_parameters {
    mode = "${try(enumerated_parameters.mode, "regexp")}"
%{ if try(enumerated_parameters.mode, "regexp") == "regexp" ~}
    name_regexps          = [${join(", ", [for r in try(enumerated_parameters.name_regexps, [""]) : "\"${r}\""])}]
    value_regexps         = [${join(", ", [for r in try(enumerated_parameters.value_regexps, [""]) : "\"${r}\""])}]
    additional_parameters = ${try(enumerated_parameters.additional_parameters, false)}
    plain_parameters      = ${try(enumerated_parameters.plain_parameters, false)}
%{ endif ~}
