%{ endif ~}
%{ if resource_type == "wallarm_rule_uploads" ~}
  file_type = "${file_type}"
%{ endif ~}
%{ if contains(["wallarm_rule_mode", "wallarm_rule_file_upload_size_limit", "wallarm_rule_overlimit_res_settings", "wallarm_rule_graphql_detection", "wallarm_rule_brute", "wallarm_rule_bola", "wallarm_rule_enum", "wallarm_rule_rate_limit_enum", "wallarm_rule_forced_browsing"], resource_type) ~}
  mode = "${mode}"
%{ endif ~}
%{ if resource_type == "wallarm_rule_file_upload_size_limit" ~}
  size      = ${size}
