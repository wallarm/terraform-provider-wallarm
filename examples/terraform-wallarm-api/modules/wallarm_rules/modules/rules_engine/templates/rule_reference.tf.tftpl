  introspection     = ${introspection}
  debug_enabled     = ${debug_enabled}
%{ endif ~}
%{ if resource_type == "wallarm_rule_credential_stuffing_point" ~}
  cred_stuff_type = "${cred_stuff_type}"
%{ if length(login_point) > 0 ~}
  login_point = ${jsonencode(login_point)}
%{ else ~}
  login_point = []
%{ endif ~}
%{ endif ~}
%{ if resource_type == "wallarm_rule_credential_stuffing_regex" ~}
  regex           = "${regex}"
